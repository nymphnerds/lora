{
  "manifest_version": 1,
  "id": "lora",
  "name": "LoRA",
  "short_name": "LO",
  "version": "0.1.23",
  "description": "Z-Image Turbo LoRA training stack using AI Toolkit, packaged as an installable Nymph module.",
  "category": "training",
  "packaging": "repo",
  "repo": {
    "url": "https://github.com/nymphnerds/lora.git",
    "branch": "main"
  },
  "source": {
    "type": "repo",
    "repo": "https://github.com/nymphnerds/lora.git",
    "ref": "main"
  },
  "overview": {
    "body": "A LoRA is a small training file that teaches Z-Image Turbo a specific character, outfit, object, style, or subject without replacing the whole base model. You train it from your own images, then use the finished LoRA in generation to reproduce that look.\n\nThis module installs a local Z-Image Turbo LoRA training workspace at $HOME/LoRA using AI Toolkit. It creates the trainer runtime, Easy LoRA beginner UI, advanced AI Toolkit UI, queue worker, dataset folder, logs, generated LoRA output folder, and shared training asset folders.\n\nFirst-time setup:\n1. Install sets up the trainer app and tools only.\n2. Fetch Training Assets downloads or resumes the large Z-Image Turbo training model and the required training adapter. Do this once before your first training run. This can take a while and uses a lot of disk space, but it is resumable.\n\nBeginner flow after assets are ready:\n1. Open Datasets: put each training set in its own folder with images and captions.\n2. Easy LoRA: use the beginner UI to make captions, create jobs, start training, stop jobs, and watch progress.\n3. AI Toolkit: use the official advanced UI only when you want the full training interface.\n4. Open LoRAs: find finished .safetensors files after training. Use Logs if a run needs troubleshooting.\n\nNormal Uninstall removes the trainer runtime and keeps your datasets, jobs, outputs, logs, and downloaded assets. Delete Data is the separate wipe button for those saved files.",
    "links": [
      {
        "label": "AI Toolkit",
        "url": "https://github.com/ostris/ai-toolkit"
      },
      {
        "label": "Z-Image Turbo",
        "url": "https://huggingface.co/Tongyi-MAI/Z-Image-Turbo"
      },
      {
        "label": "Training adapter",
        "url": "https://huggingface.co/ostris/zimage_turbo_training_adapter"
      }
    ],
    "requirements": [
      "Managed NymphsCore WSL distro",
      "CUDA-capable NVIDIA GPU",
      "Python 3 with venv",
      "Local Node 20 runtime"
    ]
  },
  "install": {
    "root": "$HOME/LoRA",
    "entrypoint": "scripts/install_lora.sh",
    "version_marker": "$HOME/LoRA/.nymph-module-version",
    "installed_markers": [
      "$HOME/LoRA/.nymph-module-version"
    ]
  },
  "runtime": {
    "services": [
      {
        "id": "aitk-ui",
        "host": "127.0.0.1",
        "port": 8675,
        "url": "http://127.0.0.1:8675"
      },
      {
        "id": "aitk-gradio",
        "host": "127.0.0.1",
        "port": 7861,
        "url": "http://127.0.0.1:7861"
      }
    ]
  },
  "artifacts": {
    "install_root": "$HOME/LoRA",
    "datasets_root": "$HOME/LoRA/datasets",
    "outputs_root": "$HOME/LoRA/loras",
    "jobs_root": "$HOME/LoRA/jobs",
    "config_root": "$HOME/LoRA/config",
    "logs_root": "$HOME/LoRA/logs",
    "models_root": "$HOME/LoRA/models",
    "adapters_root": "$HOME/LoRA/adapters"
  },
  "entrypoints": {
    "install": "scripts/install_lora.sh",
    "update": "scripts/lora_update.sh",
    "status": "scripts/lora_status.sh",
    "easy_lora": "scripts/lora_easy_lora.sh",
    "start": "scripts/lora_start.sh",
    "stop": "scripts/lora_stop.sh",
    "open": "scripts/lora_open.sh",
    "logs": "scripts/lora_logs.sh",
    "open_loras": "scripts/lora_open_loras.sh",
    "open_datasets": "scripts/lora_open_datasets.sh",
    "open_jobs": "scripts/lora_open_jobs.sh",
    "open_pictures": "scripts/lora_open_pictures.sh",
    "open_captions": "scripts/lora_open_captions.sh",
    "prepare_dataset": "scripts/lora_prepare_dataset.sh",
    "caption_brain": "scripts/lora_caption_brain.sh",
    "create_job": "scripts/lora_create_job.sh",
    "start_job": "scripts/lora_start_job.sh",
    "stop_job": "scripts/lora_stop_job.sh",
    "delete_job": "scripts/lora_delete_job.sh",
    "job_status": "scripts/lora_job_status.sh",
    "fetch_assets": "scripts/lora_fetch_assets.sh",
    "refresh": "scripts/lora_refresh.sh",
    "uninstall": "scripts/lora_uninstall.sh"
  },
  "ui": {
    "sort_order": 30,
    "standard_lifecycle_rail": true,
    "manager_ui": {
      "type": "local_html",
      "title": "Easy LoRA",
      "entrypoint": "ui/manager.html"
    },
    "manager_actions": [
      {
        "id": "easy_lora",
        "label": "Easy LoRA",
        "entrypoint": "easy_lora",
        "result": "open_module_ui"
      },
      {
        "id": "fetch_assets",
        "label": "Fetch Training Assets",
        "entrypoint": "fetch_assets",
        "result": "show_output"
      },
      {
        "id": "aitoolkit",
        "label": "AI Toolkit",
        "entrypoint": "start",
        "result": "open_external_browser"
      },
      {
        "id": "stop",
        "label": "Stop LoRA",
        "entrypoint": "stop",
        "result": "show_output"
      },
      {
        "id": "open_datasets",
        "label": "Open Datasets",
        "entrypoint": "open_datasets",
        "result": "open_directory"
      },
      {
        "id": "open_loras",
        "label": "Open LoRAs",
        "entrypoint": "open_loras",
        "result": "open_directory"
      },
      {
        "id": "logs",
        "label": "Logs",
        "entrypoint": "logs",
        "result": "show_output"
      }
    ]
  },
  "uninstall": {
    "supports_purge": true,
    "supports_data_delete": true,
    "requires_confirmation": true,
    "dry_run_arg": "--dry-run",
    "confirm_arg": "--yes",
    "purge_arg": "--purge",
    "data_only_arg": "--data-only",
    "preserve_by_default": [
      "datasets",
      "loras",
      "jobs",
      "config",
      "logs",
      "models",
      "adapters"
    ],
    "removes_by_default": [
      "ai-toolkit",
      ".node20",
      "run"
    ]
  },
  "dependencies": {
    "python": "3.x with venv",
    "node": "latest Node 20 local bootstrap",
    "torch": "2.9.1 cu128",
    "ai_toolkit": {
      "repo": "https://github.com/ostris/ai-toolkit.git",
      "branch": "main"
    },
    "training_model": "Tongyi-MAI/Z-Image-Turbo",
    "training_adapter": "ostris/zimage_turbo_training_adapter"
  },
  "notes": [
    "LoRA is an installer module, not a runtime dump.",
    "The custom manager page should expose datasets, jobs, generated LoRAs, UI launch, queue worker, and adapter/model readiness.",
    "Do not commit datasets, jobs, generated LoRAs, model bundles, adapter weights, venvs, Node runtimes, logs, or UI databases."
  ]
}
