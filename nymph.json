{
  "manifest_version": 1,
  "id": "lora",
  "name": "LoRA",
  "short_name": "LO",
  "version": "0.1.5",
  "description": "Z-Image Turbo LoRA training stack using AI Toolkit, packaged as an installable Nymph module.",
  "category": "training",
  "packaging": "repo",
  "repo": {
    "url": "https://github.com/nymphnerds/lora.git",
    "branch": "main"
  },
  "source": {
    "type": "repo",
    "repo": "https://github.com/nymphnerds/lora.git",
    "ref": "main"
  },
  "overview": {
    "body": "LoRA installs the Z-Image Turbo training stack as a Nymph module. It prepares an isolated AI Toolkit runtime, local Node UI, queue worker, datasets, jobs, logs, and generated LoRA output folders.\n\nInstall sets up the trainer runtime first. Use Prepare Training Assets to download or resume the large Z-Image Turbo training model bundle and training adapter before the first training run. Use AI Toolkit to open the official advanced UI after install. Easy LoRA will be added as the module-owned beginner UI after the install/status/action contract is stable.\n\nUser data is preserved by normal uninstall: datasets, jobs, generated LoRAs, config, logs, and downloaded training assets stay in the trainer root unless purge is explicitly requested.",
    "links": [
      {
        "label": "AI Toolkit",
        "url": "https://github.com/ostris/ai-toolkit"
      },
      {
        "label": "Z-Image Turbo",
        "url": "https://huggingface.co/Tongyi-MAI/Z-Image-Turbo"
      },
      {
        "label": "Training adapter",
        "url": "https://huggingface.co/ostris/zimage_turbo_training_adapter"
      }
    ],
    "requirements": [
      "Managed NymphsCore WSL distro",
      "CUDA-capable NVIDIA GPU",
      "Python 3 with venv",
      "Local Node 20 runtime"
    ]
  },
  "install": {
    "root": "$HOME/ZImage-Trainer",
    "entrypoint": "scripts/install_lora.sh",
    "version_marker": "$HOME/ZImage-Trainer/.nymph-module-version",
    "installed_markers": [
      "$HOME/ZImage-Trainer/.nymph-module-version"
    ]
  },
  "runtime": {
    "services": [
      {
        "id": "aitk-ui",
        "host": "127.0.0.1",
        "port": 8675,
        "url": "http://127.0.0.1:8675"
      },
      {
        "id": "aitk-gradio",
        "host": "127.0.0.1",
        "port": 7861,
        "url": "http://127.0.0.1:7861"
      }
    ]
  },
  "artifacts": {
    "install_root": "$HOME/ZImage-Trainer",
    "datasets_root": "$HOME/ZImage-Trainer/datasets",
    "outputs_root": "$HOME/ZImage-Trainer/loras",
    "jobs_root": "$HOME/ZImage-Trainer/jobs",
    "config_root": "$HOME/ZImage-Trainer/config",
    "logs_root": "$HOME/ZImage-Trainer/logs",
    "models_root": "$HOME/ZImage-Trainer/models",
    "adapters_root": "$HOME/ZImage-Trainer/adapters"
  },
  "entrypoints": {
    "install": "scripts/install_lora.sh",
    "update": "scripts/lora_update.sh",
    "status": "scripts/lora_status.sh",
    "start": "scripts/lora_start.sh",
    "stop": "scripts/lora_stop.sh",
    "open": "scripts/lora_open.sh",
    "logs": "scripts/lora_logs.sh",
    "open_loras": "scripts/lora_open_loras.sh",
    "open_datasets": "scripts/lora_open_datasets.sh",
    "open_jobs": "scripts/lora_open_jobs.sh",
    "fetch_assets": "scripts/lora_fetch_assets.sh",
    "refresh": "scripts/lora_refresh.sh",
    "uninstall": "scripts/lora_uninstall.sh"
  },
  "ui": {
    "sort_order": 30,
    "standard_lifecycle_rail": true,
    "manager_actions": [
      {
        "id": "aitoolkit",
        "label": "AI Toolkit",
        "entrypoint": "start",
        "result": "open_external_browser"
      },
      {
        "id": "fetch_assets",
        "label": "Prepare Training Assets",
        "entrypoint": "fetch_assets",
        "result": "show_output"
      },
      {
        "id": "open_loras",
        "label": "Open LoRAs",
        "entrypoint": "open_loras",
        "result": "open_directory"
      },
      {
        "id": "open_datasets",
        "label": "Open Datasets",
        "entrypoint": "open_datasets",
        "result": "open_directory"
      },
      {
        "id": "open_jobs",
        "label": "Open Jobs",
        "entrypoint": "open_jobs",
        "result": "open_directory"
      },
      {
        "id": "stop",
        "label": "Stop",
        "entrypoint": "stop",
        "result": "show_output"
      },
      {
        "id": "logs",
        "label": "Logs",
        "entrypoint": "logs",
        "result": "show_output"
      }
    ]
  },
  "uninstall": {
    "supports_purge": true,
    "supports_data_delete": true,
    "requires_confirmation": true,
    "dry_run_arg": "--dry-run",
    "confirm_arg": "--yes",
    "purge_arg": "--purge",
    "data_only_arg": "--data-only",
    "preserve_by_default": [
      "datasets",
      "loras",
      "jobs",
      "config",
      "logs",
      "models",
      "adapters"
    ],
    "removes_by_default": [
      "ai-toolkit",
      ".node20",
      "run"
    ]
  },
  "dependencies": {
    "python": "3.x with venv",
    "node": "latest Node 20 local bootstrap",
    "torch": "2.9.1 cu128",
    "ai_toolkit": {
      "repo": "https://github.com/ostris/ai-toolkit.git",
      "branch": "main"
    },
    "training_model": "Tongyi-MAI/Z-Image-Turbo",
    "training_adapter": "ostris/zimage_turbo_training_adapter"
  },
  "notes": [
    "LoRA is an installer module, not a runtime dump.",
    "The custom manager page should expose datasets, jobs, generated LoRAs, UI launch, queue worker, and adapter/model readiness.",
    "Do not commit datasets, jobs, generated LoRAs, model bundles, adapter weights, venvs, Node runtimes, logs, or UI databases."
  ]
}
